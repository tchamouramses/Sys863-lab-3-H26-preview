    <p class=\"text-sm font-semibold text-green-400\">\n            \\{% if p\\.result and p\\.result\\.get\\('predicted_water_usage_efficiency'\\) %\\}\n              \\{\\{ \"%\\.3f\"\\|format\\(p\\.result\\['predicted_water_usage_efficiency'\\]\\) \\}\\}\n            \\{% else %\\}—\\{% endif %\\}\n          </p>\n        </div>\n\n        <!-- Fertilizer -->\n        <div class=\"flex-1 min-w-0\">\n          <p class=\"text-xs text-white/40\">Engrais opt\\.</p>\n          <p class=\"text-sm font-semibold text-white\">\n            \\{% if p\\.result and p\\.result\\.get\\('recommendation'\\) %\\}\n              \\{\\{ \"%\\.1f\"\\|format\\(p\\.result\\['recommendation'\\]\\['fertilizer_usage'\\]\\) \\}\\} kg/ha\n            \\{% else %\\}—\\{% endif %\\}\n          </p>\n        </div>\n\n        <!-- Irrigation -->\n        <div class=\"flex-1 min-w-0\">\n          <p class=\"text-xs text-white/40\">Irrigation</p>\n          <p class=\"text-sm font-semibold text-white\">\n            \\{% if p\\.result and p\\.result\\.get\\('recommendation'\\) %\\}\n              \\{\\{ p\\.result\\['recommendation'\\]\\['irrigation_frequency'\\] \\}\\} × / sem\\.\n            \\{% else %\\}—\\{% endif %\\}\n          </p>\n        </div>\n\n        <!-- Badge -->\n        <div class=\"flex-shrink-0\">\n          \\{% if p\\.is_free %\\}\n          <span class=\"text-xs font-semibold badge-active rounded-full px-2\\.5 py-1\">Gratuit</span>\n          \\{% elif p\\.subscription_id %\\}\n          <span class=\"text-xs font-semibold badge-active rounded-full px-2\\.5 py-1\">Abonné</span>\n          \\{% else %\\}\n          <span class=\"text-xs font-semibold badge-pending rounded-full px-2\\.5 py-1\">1 CAD</span>\n          \\{% endif %\\}\n        </div>\n\n        <!-- Expand toggle -->\n        <button onclick=\"this\\.closest\\('\\.glass'\\)\\.querySelector\\('\\.detail-panel'\\)\\.classList\\.toggle\\('hidden'\\)\"\n          class=\"text-xs text-white/30 hover:text-white/60 transition\">\n          <svg class=\"w-4 h-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"2\" stroke=\"currentColor\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M19\\.5 8\\.25l-7\\.5 7\\.5-7\\.5-7\\.5\" />\n          </svg>\n        </button>\n      </div>\n\n      <!-- Detail panel \\(collapsed by default\\) -->\n      <div class=\"detail-panel hidden border-t border-white/10 px-5 py-4\">\n        <div class=\"grid grid-cols-2 gap-4 text-xs\">\n          <div>\n            <p class=\"text-white/40 mb-1\\.5 uppercase tracking-wider font-semibold\">Paramètres envoyés</p>\n            <pre class=\"text-white/60 leading-relaxed overflow-auto max-h-48\">\\{\\{ p\\.payload \\| tojson\\(indent=2\\) if p\\.payload else '\\{\\}' \\}\\}</pre>\n          </div>\n          <div>\n            <p class=\"text-white/40 mb-1\\.5 uppercase tracking-wider font-semibold\">Résultat complet</p>\n            \\{% set clean = \\{\\} %\\}\n            \\{% if p\\.result %\\}\n              \\{% for k, v in p\\.result\\.items\\(\\) if k != '_meta' %\\}\n                \\{% set _ = clean\\.update\\(\\{k: v\\}\\) %\\}\n              \\{% endfor %\\}\n            \\{% endif %\\}\n            <pre class=\"text-white/60 leading-relaxed overflow-auto max-h-48\">\\{\\{ clean \\| tojson\\(indent=2\\) \\}\\}</pre>\n          </div>\n        </div>\n      </div>\n    </div>\n    \\{% endfor %\\}\n  </div>\n\n  \\{% else %\\}\n  <div class=\"glass rounded-2xl p-12 text-center\">\n    <svg class=\"w-10 h-10 text-white/20 mx-auto mb-3\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1\\.5\" stroke=\"currentColor\">\n      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 12h3\\.75M9 15h3\\.75M9 18h3\\.75m3 \\.75H18a2\\.25 2\\.25 0 002\\.25-2\\.25V6\\.108c0-1\\.135-\\.845-2\\.098-1\\.976-2\\.192a48\\.424 48\\.424 0 00-1\\.123-\\.08m-5\\.801 0c-\\.065\\.21-\\.1\\.433-\\.1\\.664 0 \\.414\\.336\\.75\\.75\\.75h4\\.5a\\.75\\.75 0 00\\.75-\\.75 3\\.75 3\\.75 0 00-\\.1-\\.664m-5\\.8 0A2\\.251 2\\.251 0 0113\\.5 2\\.25H15c1\\.012 0 1\\.867\\.668 2\\.15 1\\.586m-5\\.8 0c-\\.376\\.023-\\.75\\.05-1\\.124\\.08C9\\.095 4\\.01 8\\.25 4\\.973 8\\.25 6\\.108V19\\.5a2\\.25 2\\.25 0 002\\.25 2\\.25h\\.75\" />\n    </svg>\n    <p class=\"text-white/40 text-sm\">Aucune prédiction pour le moment\\.</p>\n    <a href=\"\\{\\{ url_for\\('main\\.home'\\) \\}\\}\" class=\"inline-block mt-4 bg-green-600 hover:bg-green-700 text-white text-xs font-semibold rounded-xl px-4 py-2\\.5 transition\">\n      Faire ma première prédiction\n    </a>\n  </div>\n  \\{% endif %\\}\n</div>\n\\{% endblock %\\}\"\"\"\n\nwith open\\(\"app/templates/dashboard/history\\.html\", \"w\", encoding=\"utf-8\"\\) as f:\n    f\\.write\\(history_html\\)\n\nsubs_html = r\"\"\"\\{% extends \"base\\.html\" %\\}\n\\{% block title %\\}Abonnements\\{% endblock %\\}\n\\{% block content %\\}\n<div class=\"max-w-5xl mx-auto px-4 py-7 sm:px-6\">\n  <div class=\"flex items-center justify-between mb-5\">\n    <div>\n      <h1 class=\"font-display font-bold text-2xl text-white\">Mes abonnements</h1>\n      <p class=\"text-white/40 text-sm mt-1\">Historique de vos forfaits mensuels</p>\n    </div>\n    \\{% if not current_user\\.active_subscription %\\}\n    <form method=\"POST\" action=\"\\{\\{ url_for\\('payments\\.checkout_subscribe'\\) \\}\\}\">\n      <button type=\"submit\" class=\"flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white text-xs font-semibold rounded-xl px-4 py-2\\.5 transition\">\n        <svg class=\"w-4 h-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"2\" stroke=\"currentColor\">\n          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 4\\.5v15m7\\.5-7\\.5h-15\" />\n        </svg>\n        S'abonner — 10 CAD / mois\n      </button>\n    </form>\n    \\{% endif %\\}\n  </div>\n\n  <!-- Active subscription highlight -->\n  \\{% set active = current_user\\.active_subscription %\\}\n  \\{% if active %\\}\n  <div class=\"glass rounded-2xl border border-green-500/30 p-6 mb-5\">\n    <div class=\"flex items-center justify-between flex-wrap gap-4\">\n      <div>\n        <p class=\"text-xs text-green-400/70 uppercase tracking-wider font-semibold mb-1\">Abonnement actif</p>\n        <p class=\"font-display font-bold text-xl text-white\">10,00 CAD / mois</p>\n        <p class=\"text-sm text-white/50 mt-1\">Valide jusqu'au \\{\\{ active\\.end_date\\.strftime\\('%d %B %Y'\\) \\}\\}</p>\n      </div>\n      <div class=\"flex flex-col items-end gap-2\">\n        <span class=\"badge-active rounded-full px-3 py-1 text-sm font-semibold\">Actif</span>\n        <p class=\"text-xs text-white/30\">Renouvellement automatique via Stripe</p>\n      </div>\n    </div>\n    <!-- Progress bar days remaining -->\n    \\{% set days_total = \\(active\\.end_date - active\\.start_date\\)\\.days %\\}\n    \\{% set days_left  = \\(active\\.end_date - now\\)\\.days %\\}\n    \\{% set pct = \\[\\(days_left / days_total \\* 100\\) \\| int, 100\\] \\| min %\\}\n    <div class=\"mt-4\">\n      <div class=\"flex justify-between text-xs text-white/30 mb-1\">\n        <span>\\{\\{ days_left \\}\\} jour\\{\\{ 's' if days_left != 1 \\}\\} restant\\{\\{ 's' if days_left != 1 \\}\\}</span>\n        <span>\\{\\{ days_total \\}\\} jours au total</span>\n      </div>\n      <div class=\"bg-white/10 rounded-full h-1\\.5 overflow-hidden\">\n        <div class=\"h-full bg-green-500 rounded-full transition-all duration-700\" style=\"width:\\{\\{ pct \\}\\}%\"></div>\n      </div>\n    </div>\n  </div>\n  \\{% endif %\\}\n\n  <!-- History table -->\n  \\{% if subscriptions %\\}\n  <div class=\"glass rounded-2xl overflow-hidden\">\n    <table class=\"w-full text-sm\">\n      <thead>\n        <tr class=\"border-b border-white/10\">\n          <th class=\"text-left text-xs font-semibold text-white/40 uppercase tracking-wider px-5 py-3\">Début</th>\n          <th class=\"text-left text-xs font-semibold text-white/40 uppercase tracking-wider px-3 py-3\">Expiration</th>\n          <th class=\"text-left text-xs font-semibold text-white/40 uppercase tracking-wider px-3 py-3\">Montant</th>\n          <th class=\"text-left text-xs font-semibold text-white/40 uppercase tracking-wider px-3 py-3\">Statut</th>\n          <th class=\"text-left text-xs font-semibold text-white/40 uppercase tracking-wider px-3 py-3 hidden lg:table-cell\">ID Stripe</th>\n        </tr>\n      </thead>\n      <tbody>\n        \\{% for s in subscriptions %\\}\n        <tr class=\"border-b border-white/5 hover:bg-white/5 transition\">\n          <td class=\"px-5 py-4 text-white/60\">\\{\\{ s\\.start_date\\.strftime\\('%d/%m/%Y'\\) if s\\.start_date else '—' \\}\\}</td>\n          <td class=\"px-3 py-4 text-white/60\">\\{\\{ s\\.end_date\\.strftime\\('%d/%m/%Y'\\)   if s\\.end_date   else '—' \\}\\}</td>\n          <td class=\"px-3 py-4 font-semibold text-white\">\\{\\{ \"%\\.2f\"\\|format\\(s\\.amount\\) \\}\\} \\{\\{ s\\.currency\\.upper\\(\\) \\}\\}</td>\n          <td class=\"px-3 py-4\">\n            <span class=\"badge-\\{\\{ s\\.status \\}\\} rounded-full px-2\\.5 py-1 text-xs font-semibold\">\n              \\{% if s\\.status == 'active'   %\\}Actif\n              \\{% elif s\\.status == 'canceled' %\\}Annulé\n              \\{% elif s\\.status == 'past_due' %\\}En retard\n              \\{% else %\\}En attente\\{% endif %\\}\n            </span>\n          </td>\n          <td class=\"px-3 py-4 text-white/30 text-xs font-mono hidden lg:table-cell\">\n            \\{\\{ \\(s\\.stripe_subscription_id or '—'\\)\\[:25\\] \\}\\}…\n          </td>\n        </tr>\n        \\{% endfor %\\}\n      </tbody>\n    </table>\n  </div>\n\n  \\{% else %\\}\n  <div class=\"glass rounded-2xl p-12 text-center\">\n    <svg class=\"w-10 h-10 text-white/20 mx-auto mb-3\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1\\.5\" stroke=\"currentColor\">\n      <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M2\\.25 8\\.25h19\\.5M2\\.25 9h19\\.5m-16\\.5 5\\.25h6m-6 2\\.25h3m-3\\.75 3h15a2\\.25 2\\.25 0 002\\.25-2\\.25V6\\.75A2\\.25 2\\.25 0 0019\\.5 4\\.5h-15a2\\.25 2\\.25 0 00-2\\.25 2\\.25v10\\.5A2\\.25 2\\.25 0 004\\.5 19\\.5z\" />\n    </svg>\n    <p class=\"text-white/40 text-sm\">Aucun abonnement pour le moment\\.</p>\n    <form method=\"POST\" action=\"\\{\\{ url_for\\('payments\\.checkout_subscribe'\\) \\}\\}\" class=\"mt-4 inline-block\">\n      <button type=\"submit\" class=\"bg-green-600 hover:bg-green-700 text-white text-xs font-semibold rounded-xl px-4 py-2\\.5 transition\">\n        S'abonner pour 10 CAD / mois\n      </button>\n    </form>\n  </div>\n  \\{% endif %\\}\n</div>\n\\{% endblock %\\}\"\"\"\n\nwith open\\(\"app/templates/dashboard/subscriptions\\.html\", \"w\", encoding=\"utf-8\"\\) as f:\n    f\\.write\\(subs_html\\)\nprint\\(\"dashboard templates written\"\\)\nPYEOF$/": {

# ── Flask ───────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string

# ── Stripe (test mode) ─────────────────────────────────────────────────
# 1. Go to https://dashboard.stripe.com (enable test mode)
# 2. Developers → API keys → copy Publishable key and Secret key
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# 3. Create a Product: Products → Add product
#    - Name: "Smart Farming Monthly"
#    - Pricing: Recurring, 10.00 CAD / month
#    - Copy the Price ID (price_...)
STRIPE_PRICE_ID_SUBSCRIPTION=price_...

# 4. (Optional) Webhook signature verification
#    Run:  stripe listen --forward-to localhost:5000/payments/webhook
#    Copy the "whsec_..." secret shown in the output
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App URL (used for Stripe success/cancel redirect URLs) ──────────────
DOMAIN=https://farminapp.calme2me.com

# ── Database (leave blank to use default: data/app.db) ─────────────────
# DATABASE_URL=sqlite:////app/data/app.db
POWERBI_API_KEY=